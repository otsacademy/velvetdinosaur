{
  "ci": {
    "collect": {
      "startServerCommand": "bash -lc 'VD_LHCI=true NEXT_PUBLIC_LHCI=true bun run start -- -p 3100 & pid=$!; trap \"kill $pid\" EXIT; until curl -sf http://localhost:3100/ >/dev/null; do sleep 1; done; curl -sf http://localhost:3100/ >/dev/null; curl -sf http://localhost:3100/about >/dev/null; wait $pid'",
      "startServerReadyPattern": "Ready in",
      "url": [
        "http://localhost:3100/",
        "http://localhost:3100/about"
      ],
      "numberOfRuns": 3,
      "settings": {
        "throttlingMethod": "provided",
        "preset": "desktop",
        "formFactor": "desktop",
        "screenEmulation": {
          "mobile": false,
          "width": 1350,
          "height": 940,
          "deviceScaleFactor": 1,
          "disabled": false
        }
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 1 }],
        "categories:accessibility": ["error", { "minScore": 1 }],
        "categories:best-practices": ["error", { "minScore": 1 }],
        "categories:seo": ["error", { "minScore": 1 }]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci/desktop"
    }
  }
}
