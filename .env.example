NODE_ENV=production
PORT=3000
PUBLIC_BASE_URL=https://example.com
NEXT_PUBLIC_BASE_URL=https://example.com
BETTERAUTH_SECRET=change-me
BETTERAUTH_URL=https://example.com
NEXT_PUBLIC_BETTERAUTH_URL=https://example.com

# NFC contact card (optional)
NFC_CONTACT_NAME=Ian Wickens
NFC_CONTACT_EMAIL=hello@velvetinosaur.com
NFC_CONTACT_WEBSITE_URL=https://velvetdinosaur.com
NFC_CONTACT_MOBILE=
NFC_CONTACT_WHATSAPP=

# tweakcn (optional)
NEXT_PUBLIC_GOOGLE_FONTS_API_KEY=

# Theme editor (central service)
# Used by /api/theme/draft + /api/theme/publish (JWT Bearer) and /api/theme/editor-link (minting token).
THEME_EDITOR_JWT_SECRET=change-me
# In production: https://theme.velvetdinosaur.com
THEME_EDITOR_ORIGIN=https://theme.velvetdinosaur.com
# Optional: force the site origin that must match token.siteOrigin (useful behind proxies).
CANONICAL_ORIGIN=https://example.com

MONGODB_URI=mongodb://user:pass@127.0.0.1:27017/vd_example?authSource=vd_example

R2_BUCKET=vd-example
R2_BUCKET_NAME=vd-example
R2_JURISDICTION=default
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-key
R2_SECRET_ACCESS_KEY=your-secret

# Cloudflare Image Resizing (optional)
# When enabled, asset images are served via /cdn-cgi/image for format conversion.
NEXT_PUBLIC_CF_IMAGE_RESIZE=false
NEXT_PUBLIC_CF_IMAGE_QUALITY=85
NEXT_PUBLIC_CF_IMAGE_FORMAT=auto

# Component store (central service)
VD_STORE_SITE_URL=https://store.example.com
VD_STORE_API_URL=https://store.example.com
VD_STORE_API_KEY=

# Optional local fallback (for offline development)
VD_COMPONENT_STORE_PATH=/opt/vdplatform/component-store
VD_COMPONENT_STORE_WRITE=false
VD_COMPONENT_STORE_ADMINS=admin@example.com
VD_COMPONENT_STORE_AUTO_BUILD=false

SHADCNBLOCKS_API_KEY=sk_live_PdzNMOUgZVRwveZqgpzVLEE_D99zlL4E
