        "type": "Process3",
        "props": {
          "id": "process",
          "heading": "How we work",
          "description": "Fixed-scope, straightforward, and focused on getting you live quickly — with a site you can actually edit.",
          "steps": [
            {
              "title": "Discovery, fixed scope & agreement (20%)",
              "description": "We’ll do a short call to understand your goals and constraints. You’ll receive a fixed scope, timeline, and a simple agreement to sign. Once signed, we book the slot and invoice the first 20%."
            },
            {
              "title": "Design & prototype (40%)",
              "description": "I design the key pages and share a clickable prototype. You review structure, messaging, and layout before build starts. When the prototype is approved, we invoice the next 40%."
            },
            {
              "title": "The build",
              "description": "I build the site in Next.js and wire up the editing experience so you can update content without touching code. You’ll get a weekly progress update, and you can start adding real content while I finish development."
